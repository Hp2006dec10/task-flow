datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  password   String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lists          List[]
  tasks          Task[]
  otps           Otp[]
  anniversaries  Anniversary[]
  emailRemindersEnabled Boolean @default(true)
}

model Otp {
  id        String   @id @default(uuid())
  code      String   // Hashed OTP code
  type      String   // "VERIFICATION" or "PASSWORD_RESET"
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model List {
  id            String        @id @default(uuid())
  name          String
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks         Task[]
  anniversaries Anniversary[]
  type          String        @default("regular")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Task {
  id          String    @id @default(uuid())
  name        String
  description String?
  dueDate     DateTime?
  priority    String    @default("medium") // "low", "medium", "high"
  status      String    @default("pending") // "pending", "in_progress", "completed"
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listId      String
  list        List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Anniversary {
  id          String   @id @default(uuid())
  name        String
  description String?
  date        DateTime
  isImportant Boolean  @default(true)
  reminderTime String  @default("8 AM")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listId      String
  list        List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
